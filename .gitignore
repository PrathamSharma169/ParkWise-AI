# =============================================
# ParkWise-AI — Git ignore rules
# =============================================

# ----- Secrets & credentials (never push) -----
.env
.env.*
!.env.example
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*token.json*
*credentials.json*
credentials.json
*.key
*.pem
.credentials
secrets/
memory/test_credentials.md

# ----- Python / backend -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
.eggs/
dist/
*.egg

# Local databases (regenerate locally)
*.db
*.sqlite
*.sqlite3
backend/parkwise.db

# Large generated clustering output (~300k row labels; not backend/data/)
backend/cluster_labels.json

# ----- Always commit (backend data & tests) -----
# backend/data/   — hotspots.json, recommendations.json (app dataset)
# backend/tests/  — API test suite
!backend/data/
!backend/data/**
!backend/tests/
!backend/tests/**

# ----- Node / frontend -----
node_modules/
frontend/node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Production builds
/build
frontend/build/
dist/
dist

*.lcov

# Generated test run output (not backend/tests/ source)
test_reports/

# Frontend/unit test coverage
/coverage
frontend/coverage/

# ----- IDE & editors -----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ----- OS junk -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----- Logs & debug -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# ----- Legacy / tooling (removed integrations) -----

.chainlit
chainlit.md
.ipynb_checkpoints/
.ac

# ----- Deployment -----
.vercel

# ----- Local data samples (large CSV) -----
sample.csv

# ----- Archives & large binaries -----
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# ----- Caches -----
.cache/
frontend/node_modules/.cache/
.eslintcache
*.tsbuildinfo

# ----- Next.js (if ever added) -----
/.next/
/out/
next-env.d.ts

# ----- Misc -----
agenthub/agents/youtube/db

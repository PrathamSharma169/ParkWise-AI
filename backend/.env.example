# Supabase Postgres — Project Settings → Database → Connection string → URI
# Use Session pooler (port 6543) on Render for runtime; direct (5432) for local import.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Google Gemini (AI explain features)
GEMINI_API_KEY=

# Load all violations into RAM on startup for fast date filtering (~154 MB).
# Set to false on low-RAM plans (slower date filter, still works via Supabase queries).
PRELOAD_VIOLATIONS=true
